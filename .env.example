# ── Site ────────────────────────────────────────────────────
# Drives canonical URLs and OG. When client procures gslawfirm.in,
# change ONLY this value and add a 301 from sunitha.sindhol.com.
NEXT_PUBLIC_SITE_URL="https://sunitha.sindhol.com"

# ── Analytics & Search Console ───────────────────────────────
NEXT_PUBLIC_GA_ID=""                  # e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GSC_VERIFICATION=""       # the content="..." value from Search Console meta tag

# ── Supabase (lead storage) ──────────────────────────────────
# Create table `leads` (see README §"Supabase schema").
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_KEY=""               # server-only, used by /api/lead

# ── Resend (lead notifications → sunithags@gmail.com) ────────
RESEND_API_KEY=""
RESEND_FROM="GS Law Firm <hello@gslawfirm.in>"
LEAD_NOTIFY_TO="sunithags@gmail.com"

# ── Upstash (rate limit, 5 submissions/hour by IP) ───────────
# If unset, /api/lead falls back to an in-memory limiter with a warning.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
