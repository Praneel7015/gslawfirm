# ── Site ────────────────────────────────────────────────────
# Drives canonical URLs, OG meta, sitemap, and JSON-LD.
# Current domain: sunitha.sindhole.com (a subdomain owned by the client).
# When client procures gslawfirm.in, see docs/DOMAIN_MIGRATION.md.
NEXT_PUBLIC_SITE_URL="https://sunitha.sindhole.com"

# ── Analytics ─────────────────────────────────────────────────
# Cloudflare Web Analytics is the primary (cookie-less, no consent
# banner required). Grab the token from Cloudflare dashboard →
# Web Analytics → Manage Site → JS snippet (token in data-cf-beacon).
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=""

# Google Analytics 4 is OPTIONAL, leave empty to disable. GA4 uses
# cookies; only enable once a DPDP-compliant consent banner is in
# place. See docs/BACKEND_SETUP.md §"Analytics decision".
NEXT_PUBLIC_GA_ID=""                  # e.g. G-XXXXXXXXXX

# ── Search Console ───────────────────────────────────────────
NEXT_PUBLIC_GSC_VERIFICATION=""       # the content="..." value from Search Console meta tag

# ── Cloudflare Turnstile (optional, bot protection on contact form)
# If empty, the contact form skips the challenge. See
# docs/CLOUDFLARE_SETUP.md §7.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ── Resend (lead notifications → sunithags@gmail.com) ────────
# Sign up at resend.com, verify the sending domain (sindhole.com),
# then create an API key. See docs/BACKEND_SETUP.md (added in M6).
RESEND_API_KEY=""
RESEND_FROM="GS Law Firm <noreply@sunitha.sindhole.com>"
LEAD_NOTIFY_TO="sunithags@gmail.com"

# ── Upstash (rate limit, 5 submissions/hour by IP) ───────────
# Optional. If unset, /api/lead falls back to an in-memory limiter
# with a console warning. Fine for low-traffic launch.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
